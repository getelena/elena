{
  "name": "@elenajs/core",
  "version": "0.15.0",
  "description": "Elena is a simple, tiny library for building Progressive Web Components.",
  "author": "Elena <hi@elenajs.com>",
  "homepage": "https://elenajs.com/",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/elena.js",
  "types": "./dist/elena.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "npm run -s clean",
    "start": "rollup -c --watch",
    "build": "NODE_OPTIONS='--no-warnings' rollup -c",
    "postbuild": "npx -p typescript tsc",
    "test": "vitest run --coverage",
    "test:visual": "npx playwright test",
    "test:visual:update": "npx playwright test --update-snapshots",
    "bench": "vitest bench",
    "bench:browser": "vitest bench --config vitest.bench.config.mjs",
    "clean": "rm -rf dist/"
  },
  "devDependencies": {
    "@vitest/browser": "4.0.18",
    "@vitest/browser-playwright": "4.0.18",
    "lit": "^3.3.0",
    "@playwright/test": "^1.58.2",
    "@rollup/plugin-terser": "0.4.4",
    "@vitest/coverage-v8": "4.0.18",
    "happy-dom": "20.7.0",
    "rollup": "4.58.0",
    "rollup-plugin-summary": "3.0.1",
    "serve": "^14.2.5",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
