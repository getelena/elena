{
  "name": "@elenajs/mcp",
  "version": "0.8.0",
  "description": "MCP server that exposes Elena component metadata, scaffolding, and authoring guidance to AI assistants.",
  "author": "Elena <hi@elenajs.com>",
  "homepage": "https://elenajs.com/",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "elena-mcp": "./src/cli.js"
  },
  "exports": {
    ".": "./src/server.js"
  },
  "files": [
    "src"
  ],
  "engines": {
    "node": ">= 20"
  },
  "scripts": {
    "format": "prettier --write \"src/**/*.js\" \"test/**/*.mjs\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "vitest": "4.0.18"
  }
}
