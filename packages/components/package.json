{
  "name": "@elenajs/components",
  "version": "1.0.0-rc.13",
  "description": "Elena component library demonstrating how to build Progressive Web Components.",
  "author": "Elena <hi@elenajs.com>",
  "homepage": "https://elenajs.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getelena/elena.git",
    "directory": "packages/components"
  },
  "bugs": {
    "url": "https://github.com/getelena/elena/issues"
  },
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/custom-elements.d.ts",
  "customElements": "dist/custom-elements.json",
  "exports": {
    ".": {
      "types": "./dist/custom-elements.d.ts",
      "import": "./dist/index.js"
    },
    "./dist/*.js": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    },
    "./dist/*.css": "./dist/*.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "npm run -s clean",
    "start": "concurrently -k --hide 1 --prefix none \"elena watch\" \"web-dev-server --node-resolve --app-index index.html --open --watch\"",
    "build": "elena build",
    "clean": "rm -rf dist/",
    "test": "vitest run"
  },
  "devDependencies": {
    "@elenajs/bundler": "^1.0.0-rc.7",
    "@elenajs/core": "^1.0.0-rc.8",
    "@web/dev-server": "0.4.6",
    "concurrently": "9.2.1",
    "happy-dom": "20.8.7",
    "vitest": "4.1.1"
  }
}
