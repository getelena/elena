{
  "name": "@elenajs/components",
  "version": "0.17.0",
  "description": "Elena component library demonstrating how to build Progressive Web Components.",
  "author": "Elena <hi@elenajs.com>",
  "homepage": "https://elenajs.com/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getelena/elena.git",
    "directory": "packages/components"
  },
  "bugs": {
    "url": "https://github.com/getelena/elena/issues"
  },
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/custom-elements.d.ts",
  "customElements": "dist/custom-elements.json",
  "exports": {
    ".": {
      "types": "./dist/custom-elements.d.ts",
      "import": "./dist/index.js"
    },
    "./dist/*.js": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js"
    },
    "./dist/*.css": "./dist/*.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "npm run -s clean",
    "start": "concurrently -k -n build,serve \"nodemon --watch src -e js,css --exec elena\" \"web-dev-server --node-resolve --app-index index.html --open --watch\"",
    "build": "elena",
    "clean": "rm -rf dist/",
    "test": "vitest run"
  },
  "dependencies": {
    "@elenajs/core": "^0.15.0"
  },
  "devDependencies": {
    "@elenajs/bundler": "^0.9.0",
    "@web/dev-server": "0.4.6",
    "concurrently": "9.1.2",
    "happy-dom": "20.7.0",
    "nodemon": "3.1.10",
    "vitest": "4.0.18"
  }
}
